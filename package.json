{
  "name": "ensureok-startup-collector",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "创业公司保障画像采集器 —— 三段式问卷 + 确定性缺口诊断反馈,纯前端,留资/埋点回流 EnsureOK 现有 API",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "catalog:test": "npm run -w @ensureok/catalog test",
    "catalog:build": "npm run -w @ensureok/catalog build",
    "catalog:typecheck": "npm run -w @ensureok/catalog typecheck",
    "rag:ingest": "npm run -w @ensureok/rag ingest",
    "rag:query": "npm run -w @ensureok/rag query --",
    "rag:test": "npm run -w @ensureok/rag test",
    "rag:typecheck": "npm run -w @ensureok/rag typecheck",
    "agent:generate": "npm run -w @ensureok/agent generate --",
    "agent:probe": "npm run -w @ensureok/agent probe:tools",
    "agent:test": "npm run -w @ensureok/agent test",
    "agent:typecheck": "npm run -w @ensureok/agent typecheck",
    "server:start": "npm run -w @ensureok/server start",
    "server:test": "npm run -w @ensureok/server test",
    "server:typecheck": "npm run -w @ensureok/server typecheck",
    "mcp:start": "npm run -w @ensureok/mcp start",
    "mcp:inspect": "npm run -w @ensureok/mcp inspect",
    "mcp:typecheck": "npm run -w @ensureok/mcp typecheck"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.10",
    "vitest": "^4.1.6"
  }
}
