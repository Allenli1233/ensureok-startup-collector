{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@ensureok/agent": ["../agent/src/index.ts"],
      "@ensureok/catalog": ["../catalog/src/index.ts"],
      "@ensureok/rag": ["../rag/src/index.ts"]
    }
  },
  "include": ["src"]
}
