{
  "name": "@ensureok/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "最小 HTTP 后端 —— 把 @ensureok/agent 方案生成包成异步任务 API(POST 建任务 / GET 轮询),供前端调用。持 OpenAI key,只在后端。",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx watch src/start.ts",
    "start:once": "tsx src/start.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ensureok/agent": "*",
    "@ensureok/catalog": "*",
    "@ensureok/rag": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.2",
    "vitest": "^4.1.6"
  }
}
